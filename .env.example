# News Digest Configuration
# Generated by setup wizard — re-run ./start.sh to change

# Your Gmail address (used to send AND receive the digest)
SMTP_EMAIL=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Get one at: https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD=your_app_password_here

# Who receives the digest (defaults to your own email)
RECIPIENT_EMAIL=your_gmail@gmail.com

# Comma-separated list of news sources (keys from sources.py)
# Options: acm_technews, mit_tech_review, nytimes_tech, bbc_tech
SELECTED_SOURCES=acm_technews,bbc_tech

# Daily delivery time (24-hour format). Leave empty for manual-only.
# The setup wizard installs a LaunchAgent (macOS), cron job (Linux),
# or Scheduled Task (Windows) at this time.
SCHEDULE_TIME=08:00
